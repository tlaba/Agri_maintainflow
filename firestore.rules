rules_version = '2';
// MaintainFlow Ag — Firestore security rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user reads/writes ONLY their own farm data.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Pro entitlement: the user may READ their own, but only the backend
    // (Cloud Functions via the Admin SDK) may WRITE it. This makes Pro
    // enforceable — the client cannot grant itself Pro.
    match /entitlements/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

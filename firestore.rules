rules_version = '2';
// MaintainFlow Ag — Firestore security rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user reads/writes ONLY their own farm data.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Pro entitlement: the user may READ their own, but only the backend
    // (Cloud Functions via the Admin SDK) may WRITE it. This makes Pro
    // enforceable — the client cannot grant itself Pro.
    match /entitlements/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Community agri-services directory (buyers / sellers / suppliers).
    // Any signed-in user may browse; a user may publish/edit/remove ONLY
    // their own listing (one per account, keyed by uid). Pro is enforced
    // in the app; basic size limits guard against abuse here.
    match /listings/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.desc is string
        && request.resource.data.desc.size() <= 240
        && request.resource.data.country is string
        && request.resource.data.country.size() <= 3;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

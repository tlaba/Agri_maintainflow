rules_version = '2';
// MaintainFlow Ag — Firestore security rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user reads/writes ONLY their own farm data.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Pro entitlement: the user may READ their own, but only the backend
    // (Cloud Functions via the Admin SDK) may WRITE it. This makes Pro
    // enforceable — the client cannot grant itself Pro.
    match /entitlements/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Community agri-services directory (buyers / sellers / suppliers).
    // Any signed-in user may browse; a user may publish/edit/remove ONLY
    // their own listing (one per account, keyed by uid). The `hidden` flag is
    // moderation state — only the backend may set it, so a user cannot
    // un-hide a moderated listing.
    match /listings/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.desc is string
        && request.resource.data.desc.size() <= 240
        && request.resource.data.country is string
        && request.resource.data.country.size() <= 3
        && request.resource.data.get('hidden', false) == false;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.desc is string
        && request.resource.data.desc.size() <= 240
        && request.resource.data.country is string
        && request.resource.data.country.size() <= 3
        && request.resource.data.get('hidden', false) == resource.data.get('hidden', false);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Abuse reports: any signed-in user may file one (the doc id embeds their
    // uid, so one report per listing). The backend reads/aggregates these;
    // clients cannot read or change them.
    match /reports/{rid} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.listingUid is string
        && request.resource.data.listingUid.size() <= 64
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 200;
      allow read, update, delete: if false;
    }

    // Public mirror of active, non-hidden listings — world-readable so guests
    // (who don't load the SDK) can fetch it via the Firestore REST API. Only
    // the backend (Cloud Function) writes it.
    match /public/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
